# Local dev (npm run dev) — production ingest profile in SHIP_GATE.md
PORT=8000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Ingest concurrency (1 = one Puppeteer scraper at a time; 2 only if you have RAM headroom)
SCRAPER_CONCURRENCY=1
AI_BATCH_SIZE=5
AI_WORKER_POOL_SIZE=2
AI_MAX_QUEUE_SIZE=500

# AI — false for fast ingest/smoke; true for local NER experiments
USE_LOCAL_AI=false
SEMANTIC_SEARCH_ENABLED=true
SEMANTIC_SEARCH_LIMIT=50

# Scraper toggles (prod ship gate disables Parks/Go/Union — enable when validated)
SCRAPER_NYC_PARKS_ENABLED=false
SCRAPER_UNION_SQUARE_ENABLED=false
SCRAPER_NYC_GO_ENABLED=false

# Geocoding
GEOCODE_DELAY_MS=2100
SKIP_GEOCODE=false
GEOCODE_AGGREGATE_MAX=75

# Persistence & health
# SQLite (local dev / tests):
# DATABASE_PATH=/app/data/database.sqlite
# PostgreSQL (production):
# DATABASE_URL=postgresql://whatsupnyc:whatsupnyc@localhost:5432/whatsupnyc
# REDIS_URL=redis://localhost:6379
# ASYNC_GEOCODE=true
# API_KEYS=comma,separated,keys (required in production for all /api/events routes)
# INGEST_API_KEY=legacy_single_key
# METRICS_TOKEN=prometheus_scrape_token
# MAPBOX_ACCESS_TOKEN=pk.your_token  (REQUIRED for accurate map pins — copy from Mapbox dashboard or VITE_MAPBOX_ACCESS_TOKEN)
# SYNC_INGEST=true (development only — forbidden in production)
# WORKER_CONCURRENCY=2
EVENTS_CACHE_TTL_MS=600000
EVENTS_STALE_MS=86400000
EVENTS_RETENTION_DAYS=7
# Retention: deletes events with ISO date before cutoff; undated/TBD rows use createdAt
SMOKE_MIN_EVENTS=35
SCRAPER_ZERO_STREAK_THRESHOLD=3
SCRAPER_HISTORY_LIMIT=5

# Deprecated realtime path (scheduled for removal)
DEPRECATED_REALTIME_ENABLED=false
REALTIME_EVENTS_ENABLED=false
GEMINI_API_KEY=your_gemini_api_key_here

# Resource limits
PG_POOL_MAX=20
BROWSER_MAX_CONCURRENT_PAGES=2
BROWSER_MAX_RSS_MB=900

# Rate limits
RATE_LIMIT_EVENTS_PER_MIN=60
RATE_LIMIT_SEMANTIC_PER_MIN=20
RATE_LIMIT_REFRESH_PER_MIN=3
SEARCH_MAX_QUERY_LENGTH=200
DEDUPE_SIMILARITY_THRESHOLD=0.85
GEOCODE_CHUNK_SIZE=10
SAVE_EVENTS_CHUNK_SIZE=50
STAGING_RETENTION_DAYS=7
WORKER_SHUTDOWN_TIMEOUT_MS=120000
