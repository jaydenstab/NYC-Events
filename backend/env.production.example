# Production template — copy to Railway/host env (never commit real values)

NODE_ENV=production
PORT=8000

# Required
DATABASE_URL=postgresql://user:pass@host:5432/whatsupnyc
REDIS_URL=redis://default:pass@host:6379
API_KEYS=public_read_key,admin_ingest_key
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token

# Public read key must match VITE_API_KEY baked into the API Docker image at build time
# METRICS_TOKEN=prometheus_scrape_token

# Ingest (worker service only — never on API)
# SCRAPER_NYC_PARKS_ENABLED=true
# SCRAPER_NYC_GO_ENABLED=true
# SCRAPER_UNION_SQUARE_ENABLED=true

# Forbidden in production
SYNC_INGEST=false

# Optional
SEMANTIC_SEARCH_ENABLED=true
PUBLIC_SITE_URL=https://your-app.up.railway.app
CORS_ORIGINS=https://your-app.up.railway.app
