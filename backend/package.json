{
  "name": "hyperlocal-backend",
  "version": "1.0.0",
  "description": "Backend for hyperlocal event aggregator",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "worker": "node worker.js",
    "migrate": "node scripts/migrate.js",
    "test": "node --test",
    "test:unit": "node --test --test-concurrency=1 test/scraperHealth.test.js test/geocodeEvents.test.js test/dbService.test.js test/eventNormalize.test.js test/validation.integration.test.js test/nycParksNormalize.test.js test/dedupe.integration.test.js test/skintParse.test.js test/ingestPipeline.test.js test/scraperContract.test.js test/scraperFixture.test.js test/jsonLdParser.test.js test/staging.integration.test.js test/readiness.test.js test/apiAuth.test.js test/metrics.test.js test/qualityApi.test.js test/vectorHybrid.test.js test/property/eventNormalize.property.test.js test/property/eventValidator.property.test.js test/property/dedupe.property.test.js",
    "test:property": "node --test test/property/*.property.test.js",
    "test:postgres": "node --test test/postgres.integration.test.js",
    "test:api": "node --test test/api.test.js",
    "test:semantic": "node --test test/semantic.test.js",
    "verify:ingest": "node scripts/verify-ingest.js",
    "verify:release": "node scripts/verify-release.js",
    "ingest": "node scripts/ingest.js",
    "db:reset": "node scripts/db-reset.js",
    "smoke-ingest": "node scripts/smoke-ingest.js",
    "cleanup-staging": "node scripts/cleanup-staging.js",
    "audit:quality": "node scripts/audit-data-quality.js",
    "bench:search": "node benchmarks/search-quality.js",
    "bench:ner": "node benchmarks/ner-accuracy.js",
    "bench:dedupe": "node benchmarks/dedupe-accuracy.js",
    "bench:ingest": "node benchmarks/ingest-throughput.js",
    "bench:scraper": "node benchmarks/scraper-accuracy.js",
    "bench:all": "node benchmarks/dedupe-accuracy.js && node benchmarks/ingest-throughput.js && node benchmarks/ner-accuracy.js && node benchmarks/scraper-accuracy.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.17.0",
    "bullmq": "^5.77.3",
    "cheerio": "^1.1.2",
    "chrono-node": "^2.9.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "node-geocoder": "^4.2.0",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.22.3",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sanitize-html": "^2.17.4",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "string-similarity": "^4.0.4",
    "zod": "^3.24.1"
  },
  "overrides": {
    "protobufjs": "^7.5.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "fast-check": "^4.8.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  }
}
